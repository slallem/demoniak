# API credentials for every provider in this repo, in one place.
#
# Setup: copy this file to "credentials.properties" (same directory) and replace each
# CHANGE_ME with a real key. That copy is git-ignored — never commit it.
#
#   cp src/main/resources/credentials.properties.example src/main/resources/credentials.properties
#
# Ollama is not listed: it talks to a local server and needs no key at all.

# Anthropic / Claude API — get a key at https://console.anthropic.com/settings/keys
anthropic.api.key=CHANGE_ME

# OpenAI API — get a key at https://platform.openai.com/api-keys
openai.api.key=CHANGE_ME

# Google Gemini API (AI Studio) — get a key at https://aistudio.google.com/apikey
google.api.key=CHANGE_ME

# Mistral API — get a key at https://console.mistral.ai/api-keys
mistral.api.key=CHANGE_ME
